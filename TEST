local function newF(sz, pos, bg, tr, parent)
    local f = Instance.new("Frame")
    f.Size = sz; f.Position = pos
    f.BackgroundColor3 = bg or C.bg
    f.BackgroundTransparency = tr or 0
    f.BorderSizePixel = 0
    if parent then f.Parent = parent end
    return f
end
local function corner(r, p) local c = Instance.new("UICorner"); c.CornerRadius = UDim.new(0, r or 8); c.Parent = p end
local function stroke(col, th2, tr, p)
    local s = Instance.new("UIStroke"); s.Color = col or C.acc
    s.Thickness = th2 or 1; s.Transparency = tr or 0.2; s.Parent = p
end
local function label(txt, sz, col, font, xa, parent)
    local l = Instance.new("TextLabel")
    l.Text = txt; l.TextSize = sz or 12
    l.TextColor3 = col or C.wht
    l.Font = font or Enum.Font.GothamBold
    l.BackgroundTransparency = 1; l.BorderSizePixel = 0
    l.TextXAlignment = xa or Enum.TextXAlignment.Left
    l.TextScaled = false; l.TextWrapped = true
    if parent then l.Parent = parent end
    return l
end
local function gradient(c1, c2, rot, parent)
    local g = Instance.new("UIGradient")
    g.Color = ColorSequence.new(c1, c2); g.Rotation = rot or 0; g.Parent = parent
end

