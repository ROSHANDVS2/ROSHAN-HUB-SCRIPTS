--  §2  THROTTLE GLOBAL (anti-lag central)
-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
local _TH = {}
local function th(k, interval, fn)
    local now = tick()
    if not _TH[k] or (now - _TH[k]) >= interval then
        _TH[k] = now
        pcall(fn)
    end
end

