local function sld(pg, txt, mn, mx, def, suf, cb)
    local rH = isMobile and 52 or 46
    local r = newF(UDim2.new(1,0,0,rH), UDim2.new(0,0,0,0), C.bg3, 0, pg)
    r.LayoutOrder = #pg:GetChildren(); corner(7, r)

    local lbl2 = label(txt, isMobile and 9 or 8, C.wht, Enum.Font.Gotham, Enum.TextXAlignment.Left, r)
    lbl2.Size = UDim2.new(0.6,0,0,16); lbl2.Position = UDim2.new(0,8,0,2); lbl2.ZIndex = 13

    local vl = label(tostring(def)..(suf or ""), isMobile and 9 or 8, C.acc, Enum.Font.GothamBold, Enum.TextXAlignment.Right, r)
    vl.Size = UDim2.new(0.4,-8,0,16); vl.Position = UDim2.new(0.6,0,0,2); vl.ZIndex = 13

    local tr = newF(UDim2.new(1,-16,0,isMobile and 7 or 5), UDim2.new(0,8,0,isMobile and 30 or 28), C.bg, 0, r)
    tr.ZIndex = 13; corner(3, tr)
    local pct = (def-mn)/(mx-mn)
    local fi = newF(UDim2.new(pct,0,1,0), UDim2.new(0,0,0,0), C.acc, 0, tr)
    fi.ZIndex = 14; corner(3, fi); gradient(C.acc, C.acc2, 0, fi)
    local th2 = newF(UDim2.new(0,isMobile and 14 or 12,0,isMobile and 14 or 12),
        UDim2.new(pct,-7,0.5,-6), C.wht, 0, tr)
    th2.ZIndex = 15; corner(7, th2)

    local val = def; local sl2 = false
    local function sv(v, fire)
        val = math.clamp(math.floor(v+0.5), mn, mx)
        local p2 = (val-mn)/(mx-mn)
        tween(fi,  {Size=UDim2.new(p2,0,1,0)}, 0.04)
        tween(th2, {Position=UDim2.new(p2,-7,0.5,-6)}, 0.04)
        vl.Text = tostring(val)..(suf or "")
        if fire and cb then pcall(cb, val) end
    end

    tr.InputBegan:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1
        or i.UserInputType == Enum.UserInputType.Touch then sl2 = true end
    end)
    UIS.InputEnded:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1
        or i.UserInputType == Enum.UserInputType.Touch then sl2 = false end
    end)
    UIS.InputChanged:Connect(function(i)
        if sl2 and (i.UserInputType == Enum.UserInputType.MouseMovement
                 or i.UserInputType == Enum.UserInputType.Touch) then
            local tx = tr.AbsolutePosition.X
            local tw3 = tr.AbsoluteSize.X
            sv(mn + math.clamp(i.Position.X-tx, 0, tw3)/tw3*(mx-mn), true)
        end
    end)
    r.MouseEnter:Connect(function() tween(r,{BackgroundColor3=Color3.fromRGB(20,9,42)},0.1) end)
    r.MouseLeave:Connect(function() tween(r,{BackgroundColor3=C.bg3},0.1) end)
    return {get=function() return val end}
end

