_G.__ROSH_V2_KILL = function()
    -- Detener farm y flags
    RF.on = false; RF.running = false
    zenOn = false; noclipOn = false; espOn = false; gooberClickOn = false

    -- Desconectar todos los HBs
    for k in pairs(HB) do hOff(k) end

    -- Desconectar HBs base
    pcall(function() _hbZen:Disconnect()    end)
    pcall(function() _hbNoclip:Disconnect() end)
    pcall(function() _hbEsp:Disconnect()    end)
    pcall(function() _hbGoober:Disconnect() end)

    -- Limpiar ESP
    clearESP()

    -- Restaurar físicas del character
    local c = LP.Character
    if c then
        for _, pt in ipairs(c:GetDescendants()) do
            if pt:IsA("BasePart") then
                pcall(function() pt.CanCollide = true; pt.CanTouch = true end)
            end
        end
        for _, ff in ipairs(c:GetChildren()) do
            if ff:IsA("ForceField") then pcall(function() ff:Destroy() end) end
        end
    end

    -- Restaurar lighting
    pcall(function()
        LIG.Brightness = 1; LIG.ClockTime = 0
        LIG.FogEnd = 1000; LIG.GlobalShadows = true
    end)

    -- Destruir GUI
    pcall(function() SG:Destroy() end)
end

