local function tpToName(names, label2)
    local hrp = HRP(); if not hrp then notif("TP ERROR","Sin character.",C.red,3); return end
    for _, n in ipairs(names) do
        local f = workspace:FindFirstChild(n, true)
        if f then
            local cf = (f:IsA("BasePart") and f.CFrame)
                    or (f.PrimaryPart and f.PrimaryPart.CFrame)
            if cf then
                hrp.CFrame = cf * CFrame.new(0,5,0)
                notif("TELEPORT", "→ "..label2, C.grn, 3); return
            end
        end
