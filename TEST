local HB = {}
local function hOn(k, fn)
    if HB[k] then pcall(function() HB[k]:Disconnect() end) end
    HB[k] = RS.Heartbeat:Connect(fn)
end
local function hOff(k)
    if HB[k] then
        pcall(function() HB[k]:Disconnect() end)
        HB[k] = nil
    end
end

