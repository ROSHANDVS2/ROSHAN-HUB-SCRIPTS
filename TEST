local function tpSafeRoom()
    local hrp = HRP(); if not hrp then return end
    -- Intentar saferoom / hatch
    for _, n in ipairs({"SafeRoom","Safe Room","Saferoom","saferoom","Hatch","hatch","Escape"}) do
        local f = workspace:FindFirstChild(n, true)
        if f then
            local cf = (f:IsA("BasePart") and f.CFrame) or (f.PrimaryPart and f.PrimaryPart.CFrame)
            if cf then hrp.CFrame = cf * CFrame.new(0,5,0); notif("TP","→ SafeRoom",C.grn,3); return end
        end
    end
    -- Última room, exit
    local rms = getRooms()
    if #rms > 0 then
        local ex = rms[#rms].m:FindFirstChild("Exit",true)
        if ex then
            local cf = (ex:IsA("BasePart") and ex.CFrame) or (ex.PrimaryPart and ex.PrimaryPart.CFrame)
            if cf then hrp.CFrame = cf * CFrame.new(0,5,0); notif("TP","→ Exit (última room)",C.org,3); return end
        end
    end
    notif("TP ERROR","SafeRoom no encontrada en workspace.",C.red,4)
end

