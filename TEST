-- Obtener rooms ordenadas
local function getRooms()
    local rf = workspace:FindFirstChild("Rooms")
    if not rf then return {} end
    local t = {}
    for _, m in ipairs(rf:GetChildren()) do
        local n = tonumber(m.Name)
        if n then table.insert(t, {m=m, n=n}) end
    end
    table.sort(t, function(a, b) return a.n < b.n end)
    return t
end
-- Tween helper
local function tween(obj, props, dur, style, dir)
    TW:Create(obj, TweenInfo.new(dur or 0.2,
        style or Enum.EasingStyle.Quad,
        dir   or Enum.EasingDirection.Out), props):Play()
end

