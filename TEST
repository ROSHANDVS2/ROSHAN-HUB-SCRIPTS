            tween(pill, {BackgroundColor3=C.acc}, t2)
            tween(dot,  {Position=UDim2.new(1,-14,0.5,-6), BackgroundColor3=C.wht}, t2)
        else
            tween(pill, {BackgroundColor3=C.bg}, t2)
            tween(dot,  {Position=UDim2.new(0,2,0.5,-6), BackgroundColor3=C.dim}, t2)
        end
        if cb then pcall(cb, v) end
    end
    if def then setState(true, false) end

    local ca = Instance.new("TextButton"); ca.Size = UDim2.new(1,0,1,0)
    ca.BackgroundTransparency = 1; ca.Text = ""; ca.ZIndex = 14; ca.Parent = r
    ca.MouseButton1Click:Connect(function() setState(not st, true) end)

    r.MouseEnter:Connect(function() tween(r,{BackgroundColor3=Color3.fromRGB(20,9,42)},0.1) end)
    r.MouseLeave:Connect(function() tween(r,{BackgroundColor3=C.bg3},0.1) end)

    return {get=function() return st end, set=setState}
end

