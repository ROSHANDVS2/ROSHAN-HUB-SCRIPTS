-- Función principal de farm
local function doFarm()
    if RF.running then return end
    RF.running = true
    RF.first   = true

    task.spawn(function()
        -- Esperar TIMER GUI
        local waited = 0
        repeat task.wait(0.5); waited = waited + 0.5 until
            (LP.PlayerGui:FindFirstChild("TIMER") or waited > 30)

        local TG = LP.PlayerGui:FindFirstChild("TIMER")
        if not TG then
            notif("FARM ERROR", "TIMER GUI no encontrado.", C.red, 5)
            RF.on = false; RF.running = false; return
        end

        local CH = TG:FindFirstChild("CHOICE")
        local TM = CH and CH:FindFirstChild("TIME")
        if not CH or not TM then
            notif("FARM ERROR", "CHOICE/TIME no encontrado.", C.red, 5)
            RF.on = false; RF.running = false; return
        end

        local BF = workspace:FindFirstChild("Beacons")
        if not BF then
            notif("FARM ERROR", "Beacons no encontrado. ¿Estás en modo REPRIEVE?", C.red, 5)
            RF.on = false; RF.running = false; return
        end

        local char = LP.Character or LP.CharacterAdded:Wait()
        local hrp  = char:WaitForChild("HumanoidRootPart", 30)
        if not hrp then
            notif("FARM ERROR", "HRP no encontrado.", C.red, 5)
            RF.on = false; RF.running = false; return
        end

        LP.CharacterAdded:Connect(function(c)
            char = c
            hrp  = c:WaitForChild("HumanoidRootPart", 30)
        end)

        notif("REPRIEVE FARM", "Iniciado — recolectando beacons...", C.grn, 4)

        -- ─── LOOP PRINCIPAL ───────────────────────
        while RF.on do
            task.wait(RF.wait)
            if not RF.on then break end

            -- 1. Recolectar beacons
            local beaconList = BF:GetChildren()
            for _, b in pairs(beaconList) do
                if not RF.on then break end
                if b:IsA("Part") then
                    pcall(function()
                        hrp.CFrame = b.CFrame
                        fti(hrp, b, 0)
                        fti(hrp, b, 1)
                        RF.beacons = RF.beacons + 1
                    end)
                    task.wait(RF.first and 0.08 or (1/math.max(RF.bps, 1)))
                end
            end

            if not RF.on then break end
            task.wait(0.2)

            -- 2. XP Fires en batches (sin freezear)
            CH.Visible = true
            GUI.SelectedObject = TM

            local batchSize = isMobile and 200 or 500
            local totalBatches = math.ceil(RF.iter / batchSize)
            for b = 1, totalBatches do
                if not RF.on then break end
                for _ = 1, batchSize do
                    if VIM then
                        pcall(function()
                            VIM:SendKeyEvent(true,  Enum.KeyCode.Return, false, game)
                            VIM:SendKeyEvent(false, Enum.KeyCode.Return, false, game)
                        end)
                    else
                        -- Fallback: fire input via UIS
                        pcall(function()
                            local fakeInput = {KeyCode=Enum.KeyCode.Return, UserInputType=Enum.UserInputType.Keyboard}
                        end)
                    end
                    RF.fires = RF.fires + 1
                end
                task.wait(isMobile and 0.02 or 0.01)  -- micro-pausa anti-lag
            end

            GUI.SelectedObject = nil
            RF.cycles = RF.cycles + 1

            if RF.first then task.wait(1.2); RF.first = false
            else task.wait(0.6) end
        end
        -- ─────────────────────────────────────────

        RF.running = false
        notif("REPRIEVE FARM", "Farm detenido. Ciclos: "..RF.cycles, C.org, 4)
    end)
end

