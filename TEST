-- ── Kill genérico de entidades por nombre ──
local function killByNames(names)
    for _, obj in ipairs(workspace:GetDescendants()) do
        if obj:IsA("Model") then
            local nl = obj.Name:lower()
            for _, n in ipairs(names) do
                if nl == n:lower() then pcall(function() obj:Destroy() end); break end
            end
        end
    end
end

-- ── Kill rápido por proximity con HRP ──
local killRange = 80
local function killNear()
    local hrp = HRP(); if not hrp then return end
    local myPos = hrp.Position
    for _, obj in ipairs(workspace:GetDescendants()) do
        if obj:IsA("Model") and ENT_ALL[obj.Name:lower()] then
            local rp = obj:FindFirstChild("HumanoidRootPart") or obj.PrimaryPart
            if rp and (myPos - rp.Position).Magnitude <= killRange then
                pcall(function() obj:Destroy() end)
            end
        end
    end
end

-- ── Kill críticos ──
local function killCrit()
    local hrp = HRP(); if not hrp then return end
    local myPos = hrp.Position
    for _, obj in ipairs(workspace:GetDescendants()) do
        if obj:IsA("Model") and ENT_CRIT[obj.Name:lower()] then
            local rp = obj:FindFirstChild("HumanoidRootPart") or obj.PrimaryPart
            if rp then pcall(function() obj:Destroy() end) end
        end
    end
end

