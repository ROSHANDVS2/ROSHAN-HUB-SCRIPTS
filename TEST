    if not zenOn then return end
    th("zen", 0.6, function()
        for _, room in ipairs(getRooms()) do
            for _, d in ipairs(room.m:GetDescendants()) do
                local nl = d.Name:lower()
                if nl:find("fruit") or nl:find("forbidden") or nl == "sin_trigger" then
                    pcall(function() d:Destroy() end)
